# 11_bonus_specular.rt
# BONUS: Specular highlights (Phong model)
# Shiny sphere should show a bright specular hotspot from the light
# Implementation: objects need a shininess parameter

A 0.1 20,20,30

C 0,5,-20 0,-0.15,1 70

L −6,12,0 0.9 255,255,255

pl 0,-3,0 0,1,0 80,80,100

# Matte sphere
sp −5,1,12 4 200,60,60 0

# Shiny sphere (high specular)
sp 5,1,12 4 60,60,200 300

# Medium shininess cylinder
cy 0,0,14 0,1,0 3 10 60,180,60 50
